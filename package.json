        "@playwright/test": "^1.44.0",
        "@vitest/browser": "^3.0.0",
        "@vitest/coverage-v8": "^3.0.0",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.2.5",
        "sass": "^1.77.0",
        "typescript": "^5.4.5",
        "vite": "^7.0.0",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
