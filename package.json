{
    "name": "pasaluud1945web",
    "version": "1.0.0",
    "private": true,
    "description": "Pancasila & UUD 1945 — Progressive Web App referensi Pancasila dan UUD 1945",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "generate-icons": "node scripts/generate-icons.js",
        "prebuild": "node scripts/generate-icons.js",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run --coverage",
