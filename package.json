        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "bootstrap": "^5.3.3",
        "bootstrap-icons": "^1.11.3",
        "fuse.js": "^7.0.0"
    },
    "devDependencies": {
