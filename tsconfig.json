{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "isolatedModules": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test"
    ]
}